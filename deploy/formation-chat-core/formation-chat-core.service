[Unit]
Description=Formation Chat Core
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/etc/docker-compose/formation-chat-core
ExecStart=/usr/bin/docker-compose -f /etc/docker-compose/formation-chat-core/docker-compose.yml up -d
ExecStop=/usr/bin/docker-compose -f /etc/docker-compose/formation-chat-core/docker-compose.yml down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
