{
  "name": "@formation-chat-core/local-chat-example",
  "version": "0.0.0",
  "private": true,
  "description": "Local same-origin React chat example for mock and Haystack connectors.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/dev.mjs",
    "lint": "eslint site scripts test --no-error-on-unmatched-pattern",
