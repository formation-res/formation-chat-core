{
  "name": "@formation-chat-core/browser-client",
  "version": "0.0.0",
  "private": true,
  "description": "Framework-neutral browser client for Formation Chat Core.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src test --no-error-on-unmatched-pattern",
    "test": "vitest run",
    "test:browser": "node test/browser-smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p test/tsconfig.json"
  },
  "dependencies": {
    "@formation-chat-core/protocol": "0.0.0",
    "@sinclair/typebox": "0.34.52"
  }
}
