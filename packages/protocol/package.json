{
  "name": "@formation-chat-core/protocol",
  "version": "0.0.0",
  "private": true,
  "description": "Language-neutral schemas and generated types for Formation Chat Core.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:generated": "npm run build && node scripts/generate-schemas.mjs --check",
    "generate": "npm run build && node scripts/generate-schemas.mjs",
    "lint": "eslint src test --no-error-on-unmatched-pattern",
    "test": "vitest run && npm run check:generated",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.52",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1"
  }
}
