{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "type": "object",
  "properties": {
    "cursor": {
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[A-Za-z0-9_-]+$",
      "type": "string"
    },
    "limit": {
      "minimum": 1,
      "maximum": 100,
      "default": 20,
      "type": "integer"
    }
  }
}
