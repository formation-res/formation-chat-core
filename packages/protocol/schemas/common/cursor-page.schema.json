{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "anyOf": [
    {
      "additionalProperties": true,
      "type": "object",
      "required": [
        "hasMore",
        "nextCursor"
      ],
      "properties": {
        "hasMore": {
          "const": true,
          "type": "boolean"
        },
        "nextCursor": {
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^[A-Za-z0-9_-]+$",
          "type": "string"
        }
      }
    },
    {
      "additionalProperties": true,
      "type": "object",
      "required": [
        "hasMore"
      ],
      "properties": {
        "hasMore": {
          "const": false,
          "type": "boolean"
        },
        "nextCursor": {
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^[A-Za-z0-9_-]+$",
          "type": "string"
        }
      }
    }
  ]
}
