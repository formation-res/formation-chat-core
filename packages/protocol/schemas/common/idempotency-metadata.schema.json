{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "type": "object",
  "required": [
    "idempotencyKey"
  ],
  "properties": {
    "idempotencyKey": {
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^[\\x21-\\x7E]+$",
      "type": "string"
    },
    "requestHash": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    }
  }
}
