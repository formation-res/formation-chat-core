{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "type": "object",
  "required": [
    "eventId",
    "sequence",
    "type",
    "occurredAt",
    "visibility",
    "conversationId"
  ],
  "properties": {
    "eventId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "sequence": {
      "minimum": 1,
      "maximum": 9007199254740991,
      "type": "integer"
    },
    "type": {
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9]*)+$",
      "type": "string"
    },
    "occurredAt": {
      "format": "date-time",
      "pattern": "Z$",
      "type": "string"
    },
    "visibility": {
      "anyOf": [
        {
          "const": "public",
          "type": "string"
        },
        {
          "const": "operator",
          "type": "string"
        },
        {
          "const": "internal",
          "type": "string"
        }
      ]
    },
    "conversationId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "runId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "messageId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    }
  }
}
