{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "type": "object",
  "required": [
    "error"
  ],
  "properties": {
    "error": {
      "additionalProperties": true,
      "type": "object",
      "required": [
        "code",
        "message",
        "correlationId"
      ],
      "properties": {
        "code": {
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[A-Z][A-Z0-9_]*$",
          "type": "string"
        },
        "message": {
          "minLength": 1,
          "maxLength": 512,
          "type": "string"
        },
        "correlationId": {
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
          "type": "string"
        },
        "fieldErrors": {
          "maxItems": 100,
          "type": "array",
          "items": {
            "additionalProperties": true,
            "type": "object",
            "required": [
              "field",
              "code",
              "message"
            ],
            "properties": {
              "field": {
                "minLength": 1,
                "maxLength": 256,
                "type": "string"
              },
              "code": {
                "minLength": 1,
                "maxLength": 64,
                "pattern": "^[A-Z][A-Z0-9_]*$",
                "type": "string"
              },
              "message": {
                "minLength": 1,
                "maxLength": 512,
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
