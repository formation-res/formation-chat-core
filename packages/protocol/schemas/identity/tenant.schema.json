{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "type": "object",
  "required": [
    "tenantId",
    "displayName",
    "createdAt"
  ],
  "properties": {
    "tenantId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "displayName": {
      "minLength": 1,
      "maxLength": 200,
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "pattern": "Z$",
      "type": "string"
    }
  }
}
