{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "anyOf": [
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "kind",
        "principalId"
      ],
      "properties": {
        "kind": {
          "const": "anonymous",
          "type": "string"
        },
        "principalId": {
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
          "type": "string"
        }
      }
    },
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "kind",
        "principalId",
        "issuer",
        "subject"
      ],
      "properties": {
        "kind": {
          "const": "external",
          "type": "string"
        },
        "principalId": {
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
          "type": "string"
        },
        "issuer": {
          "minLength": 1,
          "maxLength": 512,
          "type": "string"
        },
        "subject": {
          "minLength": 1,
          "maxLength": 512,
          "type": "string"
        }
      }
    }
  ]
}
