{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "siteKey",
    "assertion"
  ],
  "properties": {
    "siteKey": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "assertion": {
      "minLength": 1,
      "maxLength": 8192,
      "type": "string"
    }
  }
}
