{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "tenantId",
    "siteId",
    "principalId",
    "sessionId",
    "scopes",
    "issuedAt",
    "expiresAt"
  ],
  "properties": {
    "tenantId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "siteId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "principalId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "sessionId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "scopes": {
      "minItems": 1,
      "uniqueItems": true,
      "type": "array",
      "items": {
        "anyOf": [
          {
            "const": "conversations:read",
            "type": "string"
          },
          {
            "const": "conversations:write",
            "type": "string"
          },
          {
            "const": "events:read",
            "type": "string"
          },
          {
            "const": "inputs:write",
            "type": "string"
          }
        ]
      }
    },
    "issuedAt": {
      "format": "date-time",
      "pattern": "Z$",
      "type": "string"
    },
    "expiresAt": {
      "format": "date-time",
      "pattern": "Z$",
      "type": "string"
    }
  }
}
