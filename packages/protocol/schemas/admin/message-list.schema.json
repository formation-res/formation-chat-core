{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "data",
    "pagination"
  ],
  "properties": {
    "data": {
      "maxItems": 100,
      "type": "array",
      "items": {
        "additionalProperties": true,
        "allOf": [
          {
            "if": {
              "properties": {
                "status": {
                  "const": "completed"
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "required": [
                "completedAt"
              ],
              "properties": {
                "completedAt": {
                  "format": "date-time",
                  "pattern": "Z$",
                  "type": "string"
                },
                "parts": {
                  "type": "array",
                  "minItems": 1
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "status": {
                  "enum": [
                    "pending",
                    "streaming"
                  ]
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "not": {
                "required": [
                  "completedAt"
                ]
              }
            }
          }
        ],
        "type": "object",
        "required": [
          "messageId",
          "conversationId",
          "sequence",
          "participantId",
          "role",
          "status",
          "parts",
          "createdAt"
        ],
        "properties": {
          "messageId": {
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
            "type": "string"
          },
          "conversationId": {
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
            "type": "string"
          },
          "sequence": {
            "minimum": 1,
            "maximum": 9007199254740991,
            "type": "integer"
          },
          "participantId": {
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
            "type": "string"
          },
          "role": {
            "anyOf": [
              {
                "const": "user",
                "type": "string"
              },
              {
                "const": "assistant",
                "type": "string"
              },
              {
                "const": "system",
                "type": "string"
              }
            ]
          },
          "status": {
            "anyOf": [
              {
                "const": "pending",
                "type": "string"
              },
              {
                "const": "streaming",
                "type": "string"
              },
              {
                "const": "completed",
                "type": "string"
              },
              {
                "const": "failed",
                "type": "string"
              },
              {
                "const": "cancelled",
                "type": "string"
              }
            ]
          },
          "parts": {
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "additionalProperties": false,
                  "type": "object",
                  "required": [
                    "type",
                    "text"
                  ],
                  "properties": {
                    "type": {
                      "const": "text",
                      "type": "string"
                    },
                    "text": {
                      "minLength": 1,
                      "maxLength": 100000,
                      "type": "string"
                    }
                  }
                },
                {
                  "additionalProperties": false,
                  "type": "object",
                  "required": [
                    "type",
                    "citationId",
                    "sourceId"
                  ],
                  "properties": {
                    "type": {
                      "const": "citation",
                      "type": "string"
                    },
                    "citationId": {
                      "minLength": 1,
                      "maxLength": 128,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
                      "type": "string"
                    },
                    "sourceId": {
                      "minLength": 1,
                      "maxLength": 128,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
                      "type": "string"
                    },
                    "title": {
                      "minLength": 1,
                      "maxLength": 500,
                      "type": "string"
                    },
                    "url": {
                      "format": "uri",
                      "pattern": "^https://",
                      "maxLength": 2048,
                      "type": "string"
                    },
                    "excerpt": {
                      "maxLength": 2000,
                      "type": "string"
                    }
                  }
                },
                {
                  "additionalProperties": false,
                  "type": "object",
                  "required": [
                    "type",
                    "fileId",
                    "name"
                  ],
                  "properties": {
                    "type": {
                      "const": "file_reference",
                      "type": "string"
                    },
                    "fileId": {
                      "minLength": 1,
                      "maxLength": 128,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
                      "type": "string"
                    },
                    "name": {
                      "minLength": 1,
                      "maxLength": 500,
                      "type": "string"
                    },
                    "mediaType": {
                      "minLength": 1,
                      "maxLength": 200,
                      "type": "string"
                    },
                    "url": {
                      "format": "uri",
                      "pattern": "^https://",
                      "maxLength": 2048,
                      "type": "string"
                    }
                  }
                },
                {
                  "additionalProperties": false,
                  "type": "object",
                  "required": [
                    "type",
                    "toolCallId",
                    "label",
                    "status"
                  ],
                  "properties": {
                    "type": {
                      "const": "tool_status",
                      "type": "string"
                    },
                    "toolCallId": {
                      "minLength": 1,
                      "maxLength": 128,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
                      "type": "string"
                    },
                    "label": {
                      "minLength": 1,
                      "maxLength": 200,
                      "type": "string"
                    },
                    "status": {
                      "anyOf": [
                        {
                          "const": "started",
                          "type": "string"
                        },
                        {
                          "const": "completed",
                          "type": "string"
                        },
                        {
                          "const": "failed",
                          "type": "string"
                        }
                      ]
                    }
                  }
                },
                {
                  "additionalProperties": false,
                  "type": "object",
                  "required": [
                    "type",
                    "requestId",
                    "inputKind",
                    "purpose",
                    "label",
                    "required",
                    "status"
                  ],
                  "properties": {
                    "type": {
                      "const": "structured_input",
                      "type": "string"
                    },
                    "requestId": {
                      "minLength": 1,
                      "maxLength": 128,
                      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
                      "type": "string"
                    },
                    "inputKind": {
                      "const": "email",
                      "type": "string"
                    },
                    "purpose": {
                      "const": "handoff_email_delivery",
                      "type": "string"
                    },
                    "label": {
                      "minLength": 1,
                      "maxLength": 200,
                      "type": "string"
                    },
                    "required": {
                      "type": "boolean"
                    },
                    "status": {
                      "anyOf": [
                        {
                          "const": "pending",
                          "type": "string"
                        },
                        {
                          "const": "submitted",
                          "type": "string"
                        },
                        {
                          "const": "declined",
                          "type": "string"
                        }
                      ]
                    }
                  }
                }
              ]
            }
          },
          "createdAt": {
            "format": "date-time",
            "pattern": "Z$",
            "type": "string"
          },
          "completedAt": {
            "format": "date-time",
            "pattern": "Z$",
            "type": "string"
          }
        }
      }
    },
    "pagination": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object",
          "required": [
            "hasMore",
            "nextCursor"
          ],
          "properties": {
            "hasMore": {
              "const": true,
              "type": "boolean"
            },
            "nextCursor": {
              "minLength": 1,
              "maxLength": 512,
              "pattern": "^[A-Za-z0-9_-]+$",
              "type": "string"
            }
          }
        },
        {
          "additionalProperties": true,
          "type": "object",
          "required": [
            "hasMore"
          ],
          "properties": {
            "hasMore": {
              "const": false,
              "type": "boolean"
            },
            "nextCursor": {
              "minLength": 1,
              "maxLength": 512,
              "pattern": "^[A-Za-z0-9_-]+$",
              "type": "string"
            }
          }
        }
      ]
    }
  }
}
