{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "adminId",
    "tenantId",
    "siteIds",
    "scopes",
    "issuedAt",
    "expiresAt"
  ],
  "properties": {
    "adminId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "tenantId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "siteIds": {
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "type": "array",
      "items": {
        "minLength": 1,
        "maxLength": 128,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
        "type": "string"
      }
    },
    "scopes": {
      "minItems": 1,
      "uniqueItems": true,
      "type": "array",
      "items": {
        "anyOf": [
          {
            "const": "admin:read",
            "type": "string"
          },
          {
            "const": "admin:internal",
            "type": "string"
          }
        ]
      }
    },
    "issuedAt": {
      "format": "date-time",
      "pattern": "Z$",
      "type": "string"
    },
    "expiresAt": {
      "format": "date-time",
      "pattern": "Z$",
      "type": "string"
    }
  }
}
