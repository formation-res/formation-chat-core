{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "data",
    "pagination"
  ],
  "properties": {
    "data": {
      "maxItems": 100,
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "runId",
          "tenantId",
          "siteId",
          "conversationId",
          "userMessageId",
          "assistantMessageId",
          "agentRef",
          "status",
          "attempt",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "runId": {
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
            "type": "string"
          },
          "tenantId": {
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
            "type": "string"
          },
          "siteId": {
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
            "type": "string"
          },
          "conversationId": {
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
            "type": "string"
          },
          "userMessageId": {
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
            "type": "string"
          },
          "assistantMessageId": {
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
            "type": "string"
          },
          "agentRef": {
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
            "type": "string"
          },
          "status": {
            "anyOf": [
              {
                "const": "queued",
                "type": "string"
              },
              {
                "const": "running",
                "type": "string"
              },
              {
                "const": "waiting_for_input",
                "type": "string"
              },
              {
                "const": "completed",
                "type": "string"
              },
              {
                "const": "failed",
                "type": "string"
              },
              {
                "const": "cancel_requested",
                "type": "string"
              },
              {
                "const": "cancelled",
                "type": "string"
              }
            ]
          },
          "attempt": {
            "minimum": 0,
            "maximum": 9007199254740991,
            "type": "integer"
          },
          "errorCode": {
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Z][A-Z0-9_]*$",
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "pattern": "Z$",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "pattern": "Z$",
            "type": "string"
          },
          "completedAt": {
            "format": "date-time",
            "pattern": "Z$",
            "type": "string"
          }
        }
      }
    },
    "pagination": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object",
          "required": [
            "hasMore",
            "nextCursor"
          ],
          "properties": {
            "hasMore": {
              "const": true,
              "type": "boolean"
            },
            "nextCursor": {
              "minLength": 1,
              "maxLength": 512,
              "pattern": "^[A-Za-z0-9_-]+$",
              "type": "string"
            }
          }
        },
        {
          "additionalProperties": true,
          "type": "object",
          "required": [
            "hasMore"
          ],
          "properties": {
            "hasMore": {
              "const": false,
              "type": "boolean"
            },
            "nextCursor": {
              "minLength": 1,
              "maxLength": 512,
              "pattern": "^[A-Za-z0-9_-]+$",
              "type": "string"
            }
          }
        }
      ]
    }
  }
}
