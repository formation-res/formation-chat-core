{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "type": "object",
  "required": [
    "runId",
    "conversationId",
    "userMessageId",
    "agentRef",
    "status",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "runId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "conversationId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "userMessageId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "assistantMessageId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "agentRef": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "status": {
      "anyOf": [
        {
          "const": "queued",
          "type": "string"
        },
        {
          "const": "running",
          "type": "string"
        },
        {
          "const": "waiting_for_input",
          "type": "string"
        },
        {
          "const": "completed",
          "type": "string"
        },
        {
          "const": "failed",
          "type": "string"
        },
        {
          "const": "cancelled",
          "type": "string"
        }
      ]
    },
    "createdAt": {
      "format": "date-time",
      "pattern": "Z$",
      "type": "string"
    },
    "updatedAt": {
      "format": "date-time",
      "pattern": "Z$",
      "type": "string"
    }
  }
}
