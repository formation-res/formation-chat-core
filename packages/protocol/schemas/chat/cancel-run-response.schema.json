{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "conversationId",
    "runId",
    "cancellationStatus"
  ],
  "properties": {
    "conversationId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "runId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "cancellationStatus": {
      "anyOf": [
        {
          "const": "cancel_requested",
          "type": "string"
        },
        {
          "const": "cancelled",
          "type": "string"
        },
        {
          "const": "already_finished",
          "type": "string"
        }
      ]
    }
  }
}
