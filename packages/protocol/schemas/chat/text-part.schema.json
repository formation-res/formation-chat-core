{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "type",
    "text"
  ],
  "properties": {
    "type": {
      "const": "text",
      "type": "string"
    },
    "text": {
      "minLength": 1,
      "maxLength": 100000,
      "type": "string"
    }
  }
}
