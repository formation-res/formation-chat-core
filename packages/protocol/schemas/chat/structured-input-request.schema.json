{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "type": "object",
  "required": [
    "requestId",
    "conversationId",
    "runId",
    "inputKind",
    "purpose",
    "prompt",
    "required",
    "status",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "requestId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "conversationId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "runId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "inputKind": {
      "const": "email",
      "type": "string"
    },
    "purpose": {
      "const": "handoff_email_delivery",
      "type": "string"
    },
    "prompt": {
      "minLength": 1,
      "maxLength": 500,
      "type": "string"
    },
    "required": {
      "type": "boolean"
    },
    "status": {
      "anyOf": [
        {
          "const": "pending",
          "type": "string"
        },
        {
          "const": "submitted",
          "type": "string"
        },
        {
          "const": "declined",
          "type": "string"
        },
        {
          "const": "expired",
          "type": "string"
        }
      ]
    },
    "createdAt": {
      "format": "date-time",
      "pattern": "Z$",
      "type": "string"
    },
    "updatedAt": {
      "format": "date-time",
      "pattern": "Z$",
      "type": "string"
    }
  }
}
