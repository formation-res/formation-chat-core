{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "type",
    "fileId",
    "name"
  ],
  "properties": {
    "type": {
      "const": "file_reference",
      "type": "string"
    },
    "fileId": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
      "type": "string"
    },
    "name": {
      "minLength": 1,
      "maxLength": 500,
      "type": "string"
    },
    "mediaType": {
      "minLength": 1,
      "maxLength": 200,
      "type": "string"
    },
    "url": {
      "format": "uri",
      "pattern": "^https://",
      "maxLength": 2048,
      "type": "string"
    }
  }
}
