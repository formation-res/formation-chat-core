{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "anyOf": [
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type",
        "text"
      ],
      "properties": {
        "type": {
          "const": "text",
          "type": "string"
        },
        "text": {
          "minLength": 1,
          "maxLength": 100000,
          "type": "string"
        }
      }
    },
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type",
        "citationId",
        "sourceId"
      ],
      "properties": {
        "type": {
          "const": "citation",
          "type": "string"
        },
        "citationId": {
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
          "type": "string"
        },
        "sourceId": {
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
          "type": "string"
        },
        "title": {
          "minLength": 1,
          "maxLength": 500,
          "type": "string"
        },
        "url": {
          "format": "uri",
          "pattern": "^https://",
          "maxLength": 2048,
          "type": "string"
        },
        "excerpt": {
          "maxLength": 2000,
          "type": "string"
        }
      }
    },
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type",
        "fileId",
        "name"
      ],
      "properties": {
        "type": {
          "const": "file_reference",
          "type": "string"
        },
        "fileId": {
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "maxLength": 500,
          "type": "string"
        },
        "mediaType": {
          "minLength": 1,
          "maxLength": 200,
          "type": "string"
        },
        "url": {
          "format": "uri",
          "pattern": "^https://",
          "maxLength": 2048,
          "type": "string"
        }
      }
    },
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type",
        "toolCallId",
        "label",
        "status"
      ],
      "properties": {
        "type": {
          "const": "tool_status",
          "type": "string"
        },
        "toolCallId": {
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "maxLength": 200,
          "type": "string"
        },
        "status": {
          "anyOf": [
            {
              "const": "started",
              "type": "string"
            },
            {
              "const": "completed",
              "type": "string"
            },
            {
              "const": "failed",
              "type": "string"
            }
          ]
        }
      }
    },
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type",
        "requestId",
        "inputKind",
        "label",
        "required",
        "status"
      ],
      "properties": {
        "type": {
          "const": "structured_input",
          "type": "string"
        },
        "requestId": {
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
          "type": "string"
        },
        "inputKind": {
          "const": "email",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "maxLength": 200,
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "status": {
          "anyOf": [
            {
              "const": "pending",
              "type": "string"
            },
            {
              "const": "submitted",
              "type": "string"
            },
            {
              "const": "declined",
              "type": "string"
            }
          ]
        }
      }
    }
  ]
}
