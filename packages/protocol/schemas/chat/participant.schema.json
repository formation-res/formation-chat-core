{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "anyOf": [
    {
      "additionalProperties": true,
      "type": "object",
      "required": [
        "participantId",
        "kind",
        "principalId"
      ],
      "properties": {
        "participantId": {
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
          "type": "string"
        },
        "kind": {
          "const": "user",
          "type": "string"
        },
        "principalId": {
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
          "type": "string"
        },
        "agentRef": {
          "not": {}
        }
      }
    },
    {
      "additionalProperties": true,
      "type": "object",
      "required": [
        "participantId",
        "kind",
        "agentRef"
      ],
      "properties": {
        "participantId": {
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
          "type": "string"
        },
        "kind": {
          "const": "agent",
          "type": "string"
        },
        "principalId": {
          "not": {}
        },
        "agentRef": {
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
          "type": "string"
        }
      }
    },
    {
      "additionalProperties": true,
      "type": "object",
      "required": [
        "participantId",
        "kind"
      ],
      "properties": {
        "participantId": {
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
          "type": "string"
        },
        "kind": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "maxLength": 64,
          "not": {
            "enum": [
              "user",
              "agent"
            ]
          },
          "type": "string"
        },
        "principalId": {
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
          "type": "string"
        },
        "agentRef": {
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$",
          "type": "string"
        }
      }
    }
  ]
}
