{
  "name": "@formation-chat-core/dashboard",
  "version": "0.0.0",
  "private": true,
  "description": "Read-only operations dashboard for Formation Chat Core.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/dev.mjs",
