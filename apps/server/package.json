{
  "name": "@formation-chat-core/server",
  "version": "0.0.0",
  "private": true,
  "description": "Formation Chat Core reference HTTP service.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src test --no-error-on-unmatched-pattern",
    "start": "node dist/index.js",
    "test": "vitest run --config test/vitest.config.ts",
    "test:integration": "vitest run --config test/vitest.integration.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p test/tsconfig.json"
  },
  "devDependencies": {
    "@types/pg": "8.20.0"
  },
  "dependencies": {
    "@formation-chat-core/mock-connector": "0.0.0",
    "@formation-chat-core/protocol": "0.0.0",
    "@formation-chat-core/server-sdk": "0.0.0",
    "@sinclair/typebox": "0.34.52",
    "fastify": "5.10.0",
    "jose": "6.2.3",
    "kysely": "0.29.3",
    "pg": "8.22.0"
  }
}
